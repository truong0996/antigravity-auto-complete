{
  "name": "antigravity-auto-accept-custom",
  "displayName": "Antigravity Auto Accept (Custom)",
  "description": "Automatically accepts Antigravity agent steps.",
  "version": "0.0.1",
  "publisher": "truongle",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-auto-accept.toggle",
        "title": "Toggle Auto-Accept"
      }
    ],
    "keybindings": [
      {
        "command": "antigravity-auto-accept.toggle",
        "key": "ctrl+alt+shift+u",
        "mac": "cmd+alt+shift+u"
      }
    ],
    "configuration": {
      "title": "Antigravity Auto Accept",
      "properties": {
        "antigravity-auto-accept.interval": {
          "type": "number",
          "default": 1000,
          "description": "Interval in milliseconds to check for auto-accept commands."
        },
        "antigravity-auto-accept.commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "antigravity.agent.acceptAgentStep",
            "chatEditing.acceptAllFiles",
            "chatEditing.acceptFile"
          ],
          "description": "List of command IDs to attempt to execute automatically."
        },
        "antigravity-auto-accept.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show notification messages when commands are executed or state changes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5"
  }
}